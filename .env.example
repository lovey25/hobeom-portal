# Hobeom Portal Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# JWT Secret Key for Authentication
# IMPORTANT: Change this to a strong, random secret in production
# Generate one using: openssl rand -base64 32
JWT_SECRET=your-secret-key-change-in-production

# VAPID Keys for Web Push Notifications
# Generate new keys using: node scripts/generate-vapid-keys.js
VAPID_PUBLIC_KEY=your-vapid-public-key-here
VAPID_PRIVATE_KEY=your-vapid-private-key-here

# VAPID Subject (Email address for push notification contact)
# Use a valid email address you control
VAPID_SUBJECT=mailto:your-email@example.com

# Google Sheets (성장기록 앱)
# 시트 URL의 /d/{ID}/edit 부분
GOOGLE_SHEETS_ID=your-spreadsheet-id-here
# Service Account JSON 키 전체를 한 줄로 (private_key의 \n은 그대로 유지)
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}
